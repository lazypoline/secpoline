 };
+// cerberus patch
+#ifndef ROUND_UP_cerberus
+  #define ROUND_UP_cerberus(x, multiple) ( (((long)(x)) + multiple - 1) & (~(multiple - 1)) )
+#endif
+
+/* Upper bound on number of syscalls (arch-independent safe value) 
+	this was againts the rules in the original cerberus patch, so I changed it to a fixed value
+	error: ‘__NR_rseq’ undeclared here (not in a function)
+	plus __NR_syscalls gets redifined in arch/x86/include/generated/uapi/asm/unistd_64.h
+*/
+#define CERBERUS_MAX_SYSCALLS 1024
+
+/* Cerberus patch */
+struct cerberus_info {
+  /* Is Cerberus kernel PKU sandbox enabled within this thread */
+  unsigned char cerberus_enabled;
+
+  /* sensitive inode (inode of /proc/self/mem) */
+  unsigned long sensitive_inode;
+
+  /* This is a bitmask in which every bit represents exactly one syscall.  If
+     the bit is set to 1, then Cerberus kernel PKU sandbox bypasses ptrace and is ultra, super, duper fast
+  */
+  unsigned char cerberus_masked_syscalls[ROUND_UP_cerberus(CERBERUS_MAX_SYSCALLS, 8) / 8];
+};
+// end cerberus patch
 
