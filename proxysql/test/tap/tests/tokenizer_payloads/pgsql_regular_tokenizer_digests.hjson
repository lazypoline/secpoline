		],
		"s1": "WITH cte AS (SELECT ?) SELECT * FROM cte",
		"s2": "WITH cte AS (SELECT ?) SELECT * FROM cte",
		"s3": "WITH cte AS (SELECT ?) SELECT * FROM cte",
