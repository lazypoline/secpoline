		"description": "Type casts (PostgreSQL-specific)",
		"q": [
			"select '100'::integer",
			"select '2023-01-01'::date",
			"select '1.234'::numeric(10,2)",
			"select 'true'::boolean",
			"select '{\"key\":\"value\"}'::json",
			"select '1 day'::interval",
			"select '12.34'::money",
			"select '192.168.1.1'::inet",
			"select '(1,2)'::point"
		],
		"s1": "select ?",
