		"s3": "select ?",
		"s4": "select ?"
	},
	// ========================
	// SECTION 7: OPERATORS
	// ========================
	{
		"description": "PostgreSQL operators",
		"q": [
			"select 1 +1"
		],
		"s1": "select ? +?",
		"s2": "select ?+?",
		"s3": "select ?+?",
		"s4": "select ?+?"
	},
	{
		"description": "PostgreSQL string concatenation",
		"q": [
			"select 'foo' || 'bar' || 123",
			"select 'foo' || 'bar' || 'baz'"
		],
		"s1": "select ? || ? || ?",
		"s2": "select ? || ? || ?",
		"s3": "select ? || ? || ?",
		"s4": "select ? || ? || ?"
	},
	{
		"description": "PostgreSQL pattern matching operators",
		"q": [
			"select 'foo' ~* '^f'",
			"select 'foo' ~* 'FOO'",
			"select 'foo' ~* 'bar'",
			"select 'foo' ~* 'BAR'"
		],
		"s1": "select ? ~* ?",
		"s2": "select ? ~*?",
		"s3": "select ? ~*?",
		"s4": "select ? ~*?"
	},
	{
		"description": "JSON operators",
		"q": [
			"select '{\"key\":\"value\"}'::json -> 'key'",
			"select '[1,2,3]'::json -> 1"
		],
		"s1": "select ?-> ?",
		"s2": "select ?-> ?",
		"s3": "select ?-> ?",
		"s4": "select ?-> ?"
	},
	{
		"description": "JSON operators",
		"q": [
			"select '{\"key\":\"value\"}'::jsonb @> '{\"key\":\"value\"}'"
		],
		"s1": "select ?@> ?",
		"s2": "select ?@> ?",
		"s3": "select ?@> ?",
		"s4": "select ?@> ?"
	},
	// ========================
