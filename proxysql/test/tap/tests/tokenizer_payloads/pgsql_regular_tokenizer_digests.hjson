		"s1": "SELECT ?",
		"s2": "SELECT ?",
		"s3": "SELECT ?",
		"s4": "SELECT ?"
	},
	{
		"description": "Space compression with strings and arrays",
		"q": [
			"SELECT\n'foo',\n\t4\n\t",
