.PHONY : util.c.o

util.i: util.c.i
.PHONY : util.i

# target to preprocess a source file
util.c.i:
	cd /home/ruben-sturm/secpoline/build && $(MAKE) $(MAKESILENT) -f secpoline_loader/CMakeFiles/loader.dir/build.make secpoline_loader/CMakeFiles/loader.dir/util.c.i
.PHONY : util.c.i

util.s: util.c.s
.PHONY : util.s

# target to generate assembly for a file
util.c.s:
	cd /home/ruben-sturm/secpoline/build && $(MAKE) $(MAKESILENT) -f secpoline_loader/CMakeFiles/loader.dir/build.make secpoline_loader/CMakeFiles/loader.dir/util.c.s
.PHONY : util.c.s

